<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema Base de la Aplicación -->
    <style name="Theme.ERPVirtualization" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colores Principales -->
        <item name="colorPrimary">@color/corporate_blue</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/soft_lavender</item>
        <item name="colorOnPrimaryContainer">@color/corporate_blue_dark</item>
        
        <!-- Colores Secundarios -->
        <item name="colorSecondary">@color/enterprise_green</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorSecondaryContainer">@color/soft_mint</item>
        <item name="colorOnSecondaryContainer">@color/enterprise_green_dark</item>
        
        <!-- Colores de Superficie -->
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_secondary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <!-- Colores de Fondo -->
        <item name="android:colorBackground">@color/surface_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        
        <!-- Colores de Error -->
        <item name="colorError">@color/error_red</item>
        <item name="colorOnError">@color/text_on_primary</item>
        <item name="colorErrorContainer">@color/soft_rose</item>
        <item name="colorOnErrorContainer">@color/text_primary</item>
        
        <!-- Status Bar y Navigation Bar -->
        <item name="android:statusBarColor">@color/corporate_blue</item>
        <item name="android:navigationBarColor">@color/surface_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Configuraciones de Ventana -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
    
    <!-- Estilo para Splash Screen -->
    <style name="Theme.ERPVirtualization.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/corporate_blue</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.ERPVirtualization</item>
    </style>
    
    <!-- Estilos de Texto Personalizados -->
    <style name="TextAppearance.ERP.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.ERP.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.ERP.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <style name="TextAppearance.ERP.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- Estilos de Botones -->
    <style name="Widget.ERP.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:minHeight">@dimen/button_height_md</item>
    </style>
    
    <style name="Widget.ERP.Button.Primary" parent="Widget.ERP.Button">
        <item name="backgroundTint">@color/corporate_blue</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>
    
    <style name="Widget.ERP.Button.Secondary" parent="Widget.ERP.Button">
        <item name="backgroundTint">@color/enterprise_green</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>
    
    <style name="Widget.ERP.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/corporate_blue</item>
        <item name="android:textColor">@color/corporate_blue</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
    </style>
    
    <!-- Estilos de Cards -->
    <style name="Widget.ERP.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_radius_xl</item>
        <item name="cardElevation">@dimen/elevation_md</item>
        <item name="cardBackgroundColor">@color/surface_card</item>
    </style>
    
    <style name="Widget.ERP.Card.Flat" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/corner_radius_md</item>
        <item name="cardBackgroundColor">@color/surface_secondary</item>
    </style>
    
    <!-- Estilos de Input Fields -->
    <style name="Widget.ERP.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_md</item>
        <item name="boxStrokeColor">@color/corporate_blue</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>
    
    <!-- Estilos de Progress Indicators -->
    <style name="Widget.ERP.CircularProgressIndicator" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/corporate_blue</item>
        <item name="trackColor">@color/soft_lavender</item>
        <item name="indicatorSize">@dimen/progress_indicator_size</item>
    </style>
    
    <!-- Estilos de Chips -->
    <style name="Widget.ERP.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/corner_radius_lg</item>
        <item name="chipBackgroundColor">@color/soft_lavender</item>
        <item name="android:textColor">@color/corporate_blue</item>
    </style>
    
    <!-- Estilos de Bottom Navigation -->
    <style name="Widget.ERP.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/corporate_blue</item>
        <item name="itemTextColor">@color/corporate_blue</item>
        <item name="android:background">@color/surface_card</item>
        <item name="elevation">@dimen/elevation_lg</item>
    </style>
    
    <!-- Estilos de Toolbar -->
    <style name="Widget.ERP.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/corporate_blue</item>
        <item name="titleTextColor">@color/text_on_primary</item>
        <item name="subtitleTextColor">@color/text_on_primary</item>
        <item name="android:elevation">@dimen/elevation_md</item>
    </style>
</resources>