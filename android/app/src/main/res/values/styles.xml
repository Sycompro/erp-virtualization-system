<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema Base de la Aplicación -->
    <style name="Theme.ERPVirtualization" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Colores Principales -->
        <item name="colorPrimary">@color/corporate_blue</item>
        <item name="colorPrimaryDark">@color/corporate_blue_dark</item>
        <item name="colorAccent">@color/enterprise_green</item>
        <item name="android:colorBackground">@color/surface_primary</item>
        
        <!-- Status Bar y Navigation Bar -->
        <item name="android:statusBarColor">@color/corporate_blue</item>
        <item name="android:navigationBarColor">@color/surface_primary</item>
        
        <!-- Configuraciones de Ventana -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>