# Configuración del Servidor Local ERP
RAILWAY_API_URL=https://erp-virtualization-system-production.up.railway.app
LOCAL_SERVER_PORT=8081
RUST_LOG=info

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock

# Network Configuration
VNC_PORT_RANGE_START=5900
VNC_PORT_RANGE_END=5950
RDP_PORT_RANGE_START=3389
RDP_PORT_RANGE_END=3439

# Security
CONTAINER_MEMORY_LIMIT=4GB
CONTAINER_CPU_LIMIT=2.0
MAX_CONTAINERS_PER_USER=3